     \"navy\": {\n                            \"900\": \"#111418\",\n                            \"800\": \"#1a212c\",\n                            \"700\": \"#2c3645\",\n                            \"600\": \"#4a5a71\",\n                            \"500\": \"#617289\",\n                            \"100\": \"#f0f2f4\",\n                        }\n                    },\n                    fontFamily: {\n                        \"display\": [\"Manrope\", \"sans-serif\"]\n                    },\n                    borderRadius: {\n                        \"DEFAULT\": \"0.25rem\",\n                        \"lg\": \"0.5rem\",\n                        \"xl\": \"0.75rem\",\n                        \"full\": \"9999px\"\n                    },\n                },\n            },\n        }\n    </script>\n<style>\n        body {\n            font-family: 'Manrope', sans-serif;\n        }\n        .form-input:focus {\n            border-color: #2b7cee !important;\n            box-shadow: 0 0 0 1px #2b7cee !important;\n        }\n    </style>\n</head>\n<body class=\"bg-background-light dark:bg-background-dark font-display text-navy-900\">\n<div class=\"relative flex min-h-screen w-full flex-col bg-white dark:bg-background-dark overflow-x-hidden\">\n<div class=\"layout-container flex h-full grow flex-col\">\n<!-- Navigation/Header -->\n<header class=\"flex items-center justify-between whitespace-nowrap border-b border-solid border-navy-100 dark:border-navy-800 px-6 md:px-40 py-4 bg-white dark:bg-background-dark\">\n<div class=\"flex items-center gap-3 text-navy-900 dark:text-slate-100\">\n<div class=\"size-8 bg-primary rounded-lg flex items-center justify-center text-white\">\n<span class=\"material-symbols-outlined text-2xl\">medical_services</span>\n</div>\n<h2 class=\"text-navy-900 dark:text-slate-100 text-xl font-extrabold leading-tight tracking-tight\">VirtualMedic</h2>\n</div>\n<div class=\"flex items-center gap-4\">\n<a class=\"text-sm font-semibold text-navy-600 dark:text-navy-500 hover:text-primary transition-colors\" href=\"#\">Помощь</a>\n</div>\n</header>\n<main class=\"flex-1 flex items-center justify-center p-6 md:p-12\">\n<div class=\"w-full max-w-[480px] flex flex-col gap-8\">\n<!-- Title Section -->\n<div class=\"flex flex-col gap-2\">\n<h1 class=\"text-navy-900 dark:text-slate-100 text-3xl font-black leading-tight tracking-[-0.033em]\">Регистрация</h1>\n<p class=\"text-navy-500 dark:text-navy-600 text-base font-normal\">Создайте аккаунт, чтобы пользоваться услугами VirtualMedic</p>\n</div>\n<!-- Registration Form -->\n<form class=\"flex flex-col gap-5\" onsubmit=\"return false;\">\n<div class=\"flex flex-col gap-1.5\">\n<label class=\"text-navy-900 dark:text-slate-200 text-sm font-semibold leading-normal\">ФИО</label>\n<input class=\"form-input flex w-full rounded-lg text-navy-900 dark:text-slate-100 border border-navy-100 dark:border-navy-800 bg-white dark:bg-navy-900 h-14 placeholder:text-navy-500 p-4 text-base font-normal leading-normal focus:outline-none transition-all\" placeholder=\"Иванов Иван Иванович\" type=\"text\"/>\n</div>\n<div class=\"flex flex-col gap-1.5\">\n<label class=\"text-navy-900 dark:text-slate-200 text-sm font-semibold leading-normal\">Email</label>\n<input class=\"form-input flex w-full rounded-lg text-navy-900 dark:text-slate-100 border border-navy-100 dark:border-navy-800 bg-white dark:bg-navy-900 h-14 placeholder:text-navy-500 p-4 text-base font-normal leading-normal focus:outline-none transition-all\" placeholder=\"example@mail.ru\" type=\"email\"/>\n</div>\n<div class=\"flex flex-col gap-1.5\">\n<label class=\"text-navy-900 dark:text-slate-200 text-sm font-semibold leading-normal\">Номер телефона</label>\n<input class=\"form-input flex w-full rounded-lg text-navy-900 dark:text-slate-100 border border-navy-100 dark:border-navy-800 bg-white dark:bg-navy-900 h-14 placeholder:text-navy-500 p-4 text-base font-normal leading-normal focus:outline-none transition-all\" placeholder=\"+7 (___) ___-__-__\" type=\"tel\"/>\n</div>\n<div class=\"flex flex-col gap-1.5\">\n<label class=\"text-navy-900 dark:text-slate-200 text-sm font-semibold leading-normal\">Пароль</label>\n<div class=\"relative\">\n<input class=\"form-input flex w-full rounded-lg text-navy-900 dark:text-slate-100 border border-navy-100 dark:border-navy-800 bg-white dark:bg-navy-900 h-14 placeholder:text-navy-500 p-4 text-base font-normal leading-normal focus:outline-none transition-all\" placeholder=\"••••••••\" type=\"password\"/>\n<button class=\"absolute right-4 top-1/2 -translate-y-1/2 text-navy-500\" type=\"button\">\n<span class=\"material-symbols-outlined text-xl\">visibility</span>\n</button>\n</div>\n</div>\n<div class=\"flex flex-col gap-1.5\">\n<label class=\"text-navy-900 dark:text-slate-200 text-sm font-semibold leading-normal\">Подтверждение пароля</label>\n<input class=\"form-input flex w-full rounded-lg text-navy-900 dark:text-slate-100 border border-navy-100 dark:border-navy-800 bg-white dark:bg-navy-900 h-14 placeholder:text-navy-500 p-4 text-base font-normal leading-normal focus:outline-none transition-all\" placeholder=\"••••••••\" type=\"password\"/>\n</div>\n<div class=\"flex items-start gap-3 py-2\">\n<input class=\"mt-1 size-5 rounded border-navy-100 text-primary focus:ring-primary\" id=\"terms\" type=\"checkbox\"/>\n<label class=\"text-sm text-navy-600 dark:text-navy-500 leading-snug\" for=\"terms\">\n                                Я соглашаюсь с <a class=\"text-primary font-medium hover:underline\" href=\"#\">Условиями использования</a> и <a class=\"text-primary font-medium hover:underline\" href=\"#\">Политикой конфиденциальности</a>\n</label>\n</div>\n<button class=\"w-full h-14 bg-primary hover:bg-primary/90 text-white font-bold text-lg rounded-lg transition-all shadow-lg shadow-primary/20 flex items-center justify-center gap-2\">\n                            Зарегистрироваться\n                        </button>\n</form>\n<!-- Bottom Link -->\n<div class=\"flex flex-col items-center gap-4 border-t border-navy-100 dark:border-navy-800 pt-6\">\n<p class=\"text-navy-600 dark:text-navy-500 text-base\">\n                            Уже есть аккаунт? \n                            <a class=\"text-primary font-bold hover:underline ml-1\" href=\"#\">Войти</a>\n</p>\n</div>\n</div>\n</main>\n<!-- Footer Small -->\n<footer class=\"px-6 md:px-40 py-8 text-center border-t border-navy-100 dark:border-navy-800\">\n<p class=\"text-navy-500 text-sm font-normal\">© 2024 VirtualMedic. Все права защищены.</p>\n</footer>\n</div>\n</div>\n</body></html>"}
