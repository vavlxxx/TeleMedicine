\n                        \"brand-dark\": \"#0f172a\", // Slate 900\n                        \"background-light\": \"#f8fafc\",\n                        \"accent-blue\": \"#0ea5e9\", // Sky 500\n                    },\n                    fontFamily: {\n                        \"display\": [\"Manrope\", \"sans-serif\"]\n                    },\n                    borderRadius: {\n                        \"DEFAULT\": \"0.5rem\",\n                        \"lg\": \"0.75rem\",\n                        \"xl\": \"1rem\",\n                        \"2xl\": \"1.5rem\",\n                        \"full\": \"9999px\"\n                    },\n                },\n            },\n        }\n    </script>\n<style type=\"text/tailwindcss\">\n        @layer base {\n            body { @apply antialiased text-slate-900 bg-background-light; }\n        }\n        .no-scrollbar::-webkit-scrollbar { display: none; }\n        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n        .timeline-dot::before {\n            content: '';\n            @apply absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-white;\n        }\n    </style>\n</head>\n<body class=\"font-display\">\n<div class=\"relative flex min-h-screen flex-col\">\n<header class=\"flex items-center justify-between border-b border-slate-200 bg-white px-4 md:px-12 py-4 sticky top-0 z-50\">\n<div class=\"flex items-center gap-10\">\n<div class=\"flex items-center gap-2 text-brand-dark\">\n<span class=\"material-symbols-outlined text-primary text-3xl font-semibold\">medical_services</span>\n<h2 class=\"text-xl font-extrabold tracking-tight\">Virtual<span class=\"text-primary\">Medic</span></h2>\n</div>\n<nav class=\"hidden lg:flex items-center gap-8\">\n<a class=\"text-slate-600 text-[15px] font-semibold hover:text-primary transition-colors\" href=\"#\">Врачи</a>\n<a class=\"text-slate-600 text-[15px] font-semibold hover:text-primary transition-colors\" href=\"#\">Услуги</a>\n<a class=\"text-slate-600 text-[15px] font-semibold hover:text-primary transition-colors\" href=\"#\">Для клиник</a>\n<a class=\"text-slate-600 text-[15px] font-semibold hover:text-primary transition-colors\" href=\"#\">О сервисе</a>\n</nav>\n</div>\n<div class=\"flex items-center gap-4\">\n<div class=\"hidden md:flex items-center bg-slate-100 rounded-full px-4 py-2 w-64\">\n<span class=\"material-symbols-outlined text-slate-400 text-xl\">search</span>\n<input class=\"bg-transparent border-none focus:ring-0 text-sm w-full ml-2\" placeholder=\"Поиск врача или услуги\" type=\"text\"/>\n</div>\n<button class=\"flex items-center justify-center rounded-full h-11 px-6 bg-brand-dark text-white text-sm font-bold hover:bg-slate-700 transition-all\">\n                    Личный кабинет\n                </button>\n</div>\n</header>\n<main class=\"mx-auto max-w-7xl w-full px-4 md:px-12 py-8\">\n<nav class=\"flex items-center gap-2 text-sm text-slate-400 mb-8\">\n<a class=\"hover:text-primary transition-colors\" href=\"#\">Главная</a>\n<span class=\"material-symbols-outlined text-[14px]\">chevron_right</span>\n<a class=\"hover:text-primary transition-colors\" href=\"#\">Кардиологи</a>\n<span class=\"material-symbols-outlined text-[14px]\">chevron_right</span>\n<span class=\"text-slate-900 font-semibold\">Александр Иванов</span>\n</nav>\n<div class=\"grid grid-cols-1 lg:grid-cols-12 gap-8\">\n<div class=\"lg:col-span-8 space-y-8\">\n<section class=\"bg-white rounded-2xl p-8 shadow-sm border border-slate-100\">\n<div class=\"flex flex-col md:flex-row gap-8 items-start\">\n<div class=\"relative shrink-0\">\n<div class=\"w-40 h-40 md:w-48 md:h-48 rounded-2xl bg-slate-100 overflow-hidden ring-4 ring-slate-50\">\n<img alt=\"Д-р Александр Иванов\" class=\"w-full h-full object-cover\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuDTSpu7vTs-PlAi0zPgR-557L3zWfCWXg-83lbq0Bpk0uCSvvpRH1XF-9zA44gTW_WxyLNiMi1iLbtCdGQlSj6ATTo02Eoe5nnE1tClV51KUQmmHZIRkre0VeCDSGhyJTDz3KN4cJFg1V6xwA4yvRlOHAfANOtSt4YOY-pcySqyt9VdKjTTHBSEzmLaY9SJPculIxZgx56GQgfFaK25xthE-F6RwZsG8oTefYT8VAe0FFsAHjXjjyAbvD0mCTClXO9XWnTPTq8xoQL-\"/>\n</div>\n<div class=\"absolute -bottom-3 -right-3 bg-primary text-white p-2 rounded-xl shadow-lg flex items-center gap-1.5\" title=\"Проверенный эксперт\">\n<span class=\"material-symbols-outlined text-xl font-bold\">verified</span>\n</div>\n</div>\n<div class=\"flex-1 pt-2\">\n<div class=\"flex items-center gap-3 mb-2\">\n<span class=\"px-3 py-1 bg-primary-light text-primary-dark text-[11px] font-bold uppercase tracking-wider rounded-full border border-blue-100\">Проверенный эксперт</span>\n<span class=\"flex items-center gap-1 text-amber-500 font-bold text-sm\">\n<span class=\"material-symbols-outlined fill-1 text-lg\">star</span> 4.9\n                                    </span>\n</div>\n<h1 class=\"text-4xl font-extrabold text-brand-dark mb-2 tracking-tight\">Александр Иванов</h1>\n<p class=\"text-xl text-slate-500 font-medium mb-6\">Врач-кардиолог, аритмолог</p>\n<div class=\"grid grid-cols-2 md:grid-cols-3 gap-6 mb-8\">\n<div>\n<p class=\"text-xs text-slate-400 uppercase font-bold tracking-widest mb-1\">Стаж работы</p>\n<p class=\"text-brand-dark font-bold\">15 лет</p>\n</div>\n<div>\n<p class=\"text-xs text-slate-400 uppercase font-bold tracking-widest mb-1\">Категория</p>\n<p class=\"text-brand-dark font-bold\">Высшая</p>\n</div>\n<div>\n<p class=\"text-xs text-slate-400 uppercase font-bold tracking-widest mb-1\">Ученая степень</p>\n<p class=\"text-brand-dark font-bold\">К.М.Н.</p>\n</div>\n</div>\n<div class=\"flex flex-wrap gap-3\">\n<button class=\"px-6 py-3 bg-slate-100 hover:bg-slate-200 text-brand-dark font-bold rounded-xl transition-colors flex items-center gap-2\">\n<span class=\"material-symbols-outlined text-xl\">favorite</span>\n                                        В избранное\n                                    </button>\n<button class=\"p-3 border border-slate-200 rounded-xl text-slate-400 hover:text-brand-dark hover:border-brand-dark transition-all\">\n<span class=\"material-symbols-outlined\">share</span>\n</button>\n</div>\n</div>\n</div>\n</section>\n<section class=\"bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden\">\n<div class=\"flex border-b border-slate-100 px-8 overflow-x-auto no-scrollbar gap-8\">\n<button class=\"py-5 border-b-2 border-primary text-brand-dark font-bold text-sm whitespace-nowrap\">О враче</button>\n<button class=\"py-5 text-slate-400 font-bold text-sm whitespace-nowrap hover:text-brand-dark transition-colors\">Образование и опыт</button>\n<button class=\"py-5 text-slate-400 font-bold text-sm whitespace-nowrap hover:text-brand-dark transition-colors\">Отзывы (48)</button>\n<button class=\"py-5 text-slate-400 font-bold text-sm whitespace-nowrap hover:text-brand-dark transition-colors\">Публикации</button>\n</div>\n<div class=\"p-8\">\n<div class=\"prose max-w-none mb-12\">\n<h3 class=\"text-2xl font-bold text-brand-dark mb-4\">Специализация</h3>\n<p class=\"text-slate-600 leading-relaxed text-lg\">\n                                    Занимаюсь диагностикой и лечением сердечно-сосудистых заболеваний: гипертонической болезни, ишемической болезни сердца, нарушений ритма. Особое внимание уделяю превентивной кардиологии и разработке индивидуальных программ реабилитации. Использую только методы с доказанной эффективностью.\n                                </p>\n</div>\n<h3 class=\"text-2xl font-bold text-brand-dark mb-8\">Опыт и образование</h3>\n<div class=\"space-y-0 ml-4 border-l-2 border-slate-100\">\n<div class=\"relative pl-10 pb-10\">\n<div class=\"absolute -left-[17px] top-0 w-8 h-8 rounded-full bg-primary-light border-2 border-primary flex items-center justify-center z-10\">\n<span class=\"material-symbols-outlined text-primary text-base font-bold\">work</span>\n</div>\n<div class=\"flex flex-col\">\n<span class=\"text-xs font-extrabold text-primary uppercase tracking-widest mb-1\">2018 — Наст. время</span>\n<h4 class=\"text-lg font-bold text-brand-dark\">Ведущий кардиолог</h4>\n<p class=\"text-slate-500 font-medium\">НМИЦ Кардиологии им. ак. Е.И. Чазова</p>\n</div>\n</div>\n<div class=\"relative pl-10 pb-10\">\n<div class=\"absolute -left-[17px] top-0 w-8 h-8 rounded-full bg-slate-50 border-2 border-slate-200 flex items-center justify-center z-10\">\n<span class=\"material-symbols-outlined text-slate-400 text-base font-bold\">school</span>\n</div>\n<div class=\"flex flex-col\">\n<span class=\"text-xs font-extrabold text-slate-400 uppercase tracking-widest mb-1\">2012 — 2018</span>\n<h4 class=\"text-lg font-bold text-brand-dark\">Врач-кардиолог стационара</h4>\n<p class=\"text-slate-500 font-medium\">ГКБ №1 им. Н.И. Пирогова</p>\n</div>\n</div>\n<div class=\"relative pl-10\">\n<div class=\"absolute -left-[17px] top-0 w-8 h-8 rounded-full bg-slate-50 border-2 border-slate-200 flex items-center justify-center z-10\">\n<span class=\"material-symbols-outlined text-slate-400 text-base font-bold\">history_edu</span>\n</div>\n<div class=\"flex flex-col\">\n<span class=\"text-xs font-extrabold text-slate-400 uppercase tracking-widest mb-1\">2010 — 2012</span>\n<h4 class=\"text-lg font-bold text-brand-dark\">Ординатура по кардиологии</h4>\n<p class=\"text-slate-500 font-medium\">ПМГМУ им. И.М. Сеченова</p>\n</div>\n</div>\n</div>\n</div>\n</section>\n<section class=\"space-y-6\">\n<div class=\"flex items-center justify-between\">\n<h3 class=\"text-2xl font-bold text-brand-dark\">Отзывы пациентов</h3>\n<button class=\"text-primary font-bold text-sm flex items-center gap-1 hover:gap-2 transition-all\">\n                                Все 48 отзывов\n                                <span class=\"material-symbols-outlined text-lg\">arrow_right_alt</span>\n</button>\n</div>\n<div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n<div class=\"bg-white p-6 rounded-2xl border border-slate-100 shadow-sm\">\n<div class=\"flex items-center gap-4 mb-4\">\n<div class=\"w-12 h-12 rounded-full bg-slate-100 flex items-center justify-center font-bold text-slate-400\">ЕМ</div>\n<div>\n<h4 class=\"text-sm font-bold text-brand-dark\">Елена М.</h4>\n<p class=\"text-[11px] text-slate-400 font-bold uppercase tracking-widest\">12 марта 2024</p>\n</div>\n</div>\n<div class=\"flex text-amber-400 mb-3\">\n<span class=\"material-symbols-outlined text-[16px] fill-1\">star</span>\n<span class=\"material-symbols-outlined text-[16px] fill-1\">star</span>\n<span class=\"material-symbols-outlined text-[16px] fill-1\">star</span>\n<span class=\"material-symbols-outlined text-[16px] fill-1\">star</span>\n<span class=\"material-symbols-outlined text-[16px] fill-1\">star</span>\n</div>\n<p class=\"text-slate-600 leading-relaxed italic text-sm\">\"Очень внимательный доктор. Подробно объяснил результаты обследования и скорректировал лечение. Чувствую себя намного лучше!\"</p>\n</div>\n<div class=\"bg-white p-6 rounded-2xl border border-slate-100 shadow-sm\">\n<div class=\"flex items-center gap-4 mb-4\">\n<div class=\"w-12 h-12 rounded-full bg-slate-100 flex items-center justify-center font-bold text-slate-400\">ИП</div>\n<div>\n<h4 class=\"text-sm font-bold text-brand-dark\">Игорь П.</h4>\n<p class=\"text-[11px] text-slate-400 font-bold uppercase tracking-widest\">28 февраля 2024</p>\n</div>\n</div>\n<div class=\"flex text-amber-400 mb-3\">\n<span class=\"material-symbols-outlined text-[16px] fill-1\">star</span>\n<span class=\"material-symbols-outlined text-[16px] fill-1\">star</span>\n<span class=\"material-symbols-outlined text-[16px] fill-1\">star</span>\n<span class=\"material-symbols-outlined text-[16px] fill-1\">star</span>\n<span class=\"material-symbols-outlined text-[16px] fill-1\">star</span>\n</div>\n<p class=\"text-slate-600 leading-relaxed italic text-sm\">\"Профессионал своего дела. Онлайн-консультация прошла продуктивно, получил ответы на все вопросы. Рекомендую коллегам.\"</p>\n</div>\n</div>\n</section>\n</div>\n<div class=\"lg:col-span-4\">\n<aside class=\"sticky top-28 space-y-6\">\n<div class=\"bg-white rounded-3xl p-8 shadow-xl shadow-slate-200/50 border border-slate-100\">\n<div class=\"flex justify-between items-start mb-8\">\n<div>\n<p class=\"text-[11px] font-extrabold text-slate-400 uppercase tracking-widest mb-1\">Стоимость консультации</p>\n<div class=\"flex items-baseline gap-2\">\n<span class=\"text-4xl font-extrabold text-brand-dark\">3 500 ₽</span>\n<span class=\"text-slate-300 line-through font-medium\">4 500 ₽</span>\n</div>\n</div>\n<div class=\"w-12 h-12 bg-primary-light rounded-2xl flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-primary\">payments</span>\n</div>\n</div>\n<div class=\"space-y-4 mb-8\">\n<div class=\"flex items-center gap-4 p-4 rounded-2xl bg-blue-50 border border-blue-100/50\">\n<span class=\"material-symbols-outlined text-primary-dark text-2xl\">bolt</span>\n<div>\n<p class=\"text-sm font-bold text-brand-dark\">Ближайший слот</p>\n<p class=\"text-sm text-primary-dark font-extrabold\">Завтра, 14:30 (МСК)</p>\n</div>\n</div>\n<div class=\"flex items-center gap-4 p-4 rounded-2xl border border-slate-50 bg-slate-50/50\">\n<span class=\"material-symbols-outlined text-slate-400 text-2xl\">video_camera_front</span>\n<div>\n<p class=\"text-sm font-bold text-brand-dark\">Формат приема</p>\n<p class=\"text-sm text-slate-500 font-medium\">Видео, аудио или чат</p>\n</div>\n</div>\n</div>\n<div class=\"space-y-3\">\n<button class=\"w-full bg-primary hover:bg-primary-dark text-white font-extrabold py-5 rounded-2xl shadow-lg shadow-blue-200 transition-all flex items-center justify-center gap-3\">\n<span class=\"material-symbols-outlined font-bold\">chat</span>\n                                    Начать чат\n                                </button>\n<button class=\"w-full bg-brand-dark hover:bg-slate-800 text-white font-extrabold py-5 rounded-2xl transition-all flex items-center justify-center gap-3\">\n<span class=\"material-symbols-outlined font-bold\">calendar_month</span>\n                                    Записаться на прием\n                                </button>\n</div>\n<div class=\"mt-8 pt-6 border-t border-slate-50 flex items-center gap-3 text-slate-400\">\n<span class=\"material-symbols-outlined text-lg\">verified_user</span>\n<p class=\"text-[11px] font-semibold leading-tight\">Гарантия безопасности платежа и возврата средств в случае отмены</p>\n</div>\n</div>\n<div class=\"bg-brand-dark text-white rounded-3xl p-8 relative overflow-hidden group\">\n<div class=\"relative z-10\">\n<h4 class=\"font-bold text-xl mb-3\">Сложный случай?</h4>\n<p class=\"text-slate-400 text-sm mb-6 leading-relaxed\">Наш медицинский консьерж поможет подобрать нужного специалиста и подготовить документы.</p>\n<button class=\"text-primary font-bold text-sm flex items-center gap-2 group-hover:gap-3 transition-all\">\n                                    Связаться с консьержем\n                                    <span class=\"material-symbols-outlined\">arrow_right_alt</span>\n</button>\n</div>\n<span class=\"material-symbols-outlined absolute -bottom-4 -right-4 text-white/5 text-[120px] pointer-events-none\">support_agent</span>\n</div>\n</aside>\n</div>\n</div>\n</main>\n<footer class=\"bg-white border-t border-slate-200 mt-20 pt-16 pb-12\">\n<div class=\"mx-auto max-w-7xl px-4 md:px-12\">\n<div class=\"grid grid-cols-1 md:grid-cols-4 lg:grid-cols-6 gap-12 mb-16\">\n<div class=\"lg:col-span-2\">\n<div class=\"flex items-center gap-2 text-brand-dark mb-6\">\n<span class=\"material-symbols-outlined text-primary text-3xl font-semibold\">medical_services</span>\n<h2 class=\"text-xl font-extrabold tracking-tight\">Virtual<span class=\"text-primary\">Medic</span></h2>\n</div>\n<p class=\"text-slate-500 text-sm leading-relaxed mb-8 max-w-xs\">Профессиональная медицинская помощь доступная каждому. Консультации ведущих экспертов без очередей и поездок.</p>\n<div class=\"flex gap-4\">\n<a class=\"w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-400 hover:bg-primary hover:text-white transition-all\" href=\"#\"><span class=\"material-symbols-outlined text-xl\">share</span></a>\n<a class=\"w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-400 hover:bg-primary hover:text-white transition-all\" href=\"#\"><span class=\"material-symbols-outlined text-xl\">public</span></a>\n</div>\n</div>\n<div>\n<h4 class=\"font-bold text-brand-dark mb-6 text-sm uppercase tracking-widest\">Пациентам</h4>\n<ul class=\"space-y-4 text-sm font-semibold text-slate-500\">\n<li><a class=\"hover:text-primary transition-colors\" href=\"#\">Поиск врача</a></li>\n<li><a class=\"hover:text-primary transition-colors\" href=\"#\">Как это работает</a></li>\n<li><a class=\"hover:text-primary transition-colors\" href=\"#\">Стоимость услуг</a></li>\n<li><a class=\"hover:text-primary transition-colors\" href=\"#\">База знаний</a></li>\n</ul>\n</div>\n<div>\n<h4 class=\"font-bold text-brand-dark mb-6 text-sm uppercase tracking-widest\">Врачам</h4>\n<ul class=\"space-y-4 text-sm font-semibold text-slate-500\">\n<li><a class=\"hover:text-primary transition-colors\" href=\"#\">Подключить клинику</a></li>\n<li><a class=\"hover:text-primary transition-colors\" href=\"#\">Личный кабинет</a></li>\n<li><a class=\"hover:text-primary transition-colors\" href=\"#\">Партнерская программа</a></li>\n</ul>\n</div>\n<div class=\"lg:col-span-2\">\n<h4 class=\"font-bold text-brand-dark mb-6 text-sm uppercase tracking-widest\">Поддержка</h4>\n<div class=\"space-y-4\">\n<p class=\"text-2xl font-extrabold text-brand-dark\">8 (800) 555-35-35</p>\n<p class=\"text-slate-500 text-sm font-medium\">Ежедневно с 08:00 до 22:00 (МСК)</p>\n<button class=\"px-6 py-3 border border-slate-200 rounded-xl text-brand-dark font-bold text-sm hover:border-primary hover:text-primary transition-all\">\n                                Написать в чат\n                            </button>\n</div>\n</div>\n</div>\n<div class=\"pt-8 border-t border-slate-100 flex flex-col md:flex-row justify-between items-center gap-6\">\n<p class=\"text-xs text-slate-400 font-medium\">© 2024 VirtualMedic. Все права защищены. Имеются противопоказания, необходима консультация специалиста.</p>\n<div class=\"flex gap-8 text-xs font-bold text-slate-400\">\n<a class=\"hover:text-brand-dark transition-colors\" href=\"#\">Политика конфиденциальности</a>\n<a class=\"hover:text-brand-dark transition-colors\" href=\"#\">Оферта</a>\n</div>\n</div>\n</div>\n</footer>\n</div>\n\n</body></html>"}
