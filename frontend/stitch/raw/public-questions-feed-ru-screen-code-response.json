 }\n        }\n    </style>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    colors: {\n                        \"primary\": \"#2b7cee\",\n                        \"navy-text\": \"#111418\",\n                        \"muted-text\": \"#64748b\",\n                        \"border-color\": \"#e2e8f0\"\n                    },\n                    fontFamily: {\n                        \"display\": [\"Manrope\", \"sans-serif\"]\n                    },\n                    borderRadius: {\n                        \"card\": \"0.75rem\"\n                    }\n                },\n            },\n        }\n    </script>\n</head>\n<body class=\"bg-[#f8fafc] dark:bg-[#0f172a] font-display text-navy-text dark:text-slate-100 antialiased\">\n<div class=\"relative flex min-h-screen w-full flex-col overflow-x-hidden\">\n<header class=\"sticky top-0 z-50 bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800\">\n<div class=\"max-w-7xl mx-auto px-6 h-20 flex items-center justify-between\">\n<div class=\"flex items-center gap-12\">\n<div class=\"flex items-center gap-2.5\">\n<div class=\"bg-primary p-2 rounded-xl text-white shadow-sm\">\n<span class=\"material-symbols-outlined text-2xl block\">medical_services</span>\n</div>\n<span class=\"text-[#111418] dark:text-white text-xl font-extrabold tracking-tight\">Telemed<span class=\"text-primary\">RU</span></span>\n</div>\n<nav class=\"hidden lg:flex items-center gap-8\">\n<a class=\"text-muted-text dark:text-slate-400 text-sm font-semibold hover:text-primary transition-colors\" href=\"#\">Консультации</a>\n<a class=\"text-primary text-sm font-bold relative after:content-[''] after:absolute after:-bottom-[29px] after:left-0 after:w-full after:h-0.5 after:bg-primary\" href=\"#\">Вопросы</a>\n<a class=\"text-muted-text dark:text-slate-400 text-sm font-semibold hover:text-primary transition-colors\" href=